{
  "non_code": {
    "dirs": [
      "doc/"
    ],
    "exts": [
      ".md",
      ".txt",
      ".png",
      ".jpg",
      ".jpeg",
      ".svg",
      ".gif"
    ],
    "files": [
      "LICENSE",
      ".gitignore",
      ".gitattributes"
    ]
  },
  "run_all_patterns": [
    "Cargo.toml",
    "Cargo.lock",
    "rust-toolchain.toml",
    "tests.sh",
    "check.sh",
    ".github/workflows/*"
  ],
  "selection_rules": [
    {
      "id": "aarch64_path",
      "patterns": [
        "kernel/src/hal/arch/aarch64/*",
        "configs/board/qemu-aarch64.toml",
        "configs/vms/*aarch64*"
      ],
      "targets": [
        "axvisor-qemu-aarch64-arceos",
        "axvisor-qemu-aarch64-linux"
      ]
    },
    {
      "id": "x86_64_path",
      "patterns": [
        "kernel/src/hal/arch/x86_64/*",
        "platform/x86-qemu-q35/*",
        "configs/board/qemu-x86_64.toml",
        "configs/vms/*x86_64*"
      ],
      "targets": [
        "axvisor-qemu-x86_64-nimbos"
      ]
    },
    {
      "id": "phytium_path",
      "patterns": [
        "*phytium*",
        "*e2000*"
      ],
      "targets": [
        "axvisor-board-phytiumpi-arceos",
        "axvisor-board-phytiumpi-linux"
      ]
    },
    {
      "id": "rk3568_path",
      "patterns": [
        "*rk3568*",
        "*rockchip*"
      ],
      "targets": [
        "axvisor-board-roc-rk3568-pc-arceos",
        "axvisor-board-roc-rk3568-pc-linux"
      ]
    }
  ],
  "target_order": [
    "axvisor-qemu-aarch64-arceos",
    "axvisor-qemu-aarch64-linux",
    "axvisor-qemu-x86_64-nimbos",
    "axvisor-board-phytiumpi-arceos",
    "axvisor-board-phytiumpi-linux",
    "axvisor-board-roc-rk3568-pc-arceos",
    "axvisor-board-roc-rk3568-pc-linux"
  ]
}
